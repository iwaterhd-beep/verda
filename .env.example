# ──────────────────────────────────────────────────────────────
# Verda — variables de entorno
# Copia este archivo a `.env` y rellena los valores.
# ──────────────────────────────────────────────────────────────

# Base de datos (PostgreSQL / Supabase)
DATABASE_URL="postgresql://user:password@localhost:5432/verda?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/verda?schema=public"

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL="https://xxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Auth / sesiones
AUTH_SECRET="genera-uno-con: openssl rand -base64 32"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Super admin (bootstrap inicial en /super-admin/setup)
SUPER_ADMIN_BOOTSTRAP_SECRET="cambia-esto-por-una-clave-larga"

# Email transaccional (Resend)
RESEND_API_KEY=""

# Almacenamiento (documentos, fotos, firmas)
STORAGE_BUCKET="verda-documents"
